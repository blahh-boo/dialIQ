# Run mode: live | replay | mock
RUN_MODE=mock

# Database
DATABASE_URL=postgresql+psycopg://localhost:5432/mysteryshop

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# Vapi (required when RUN_MODE=live)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# ngrok static domain used for Vapi server.url (e.g. my-tunnel.ngrok.app)
NGROK_DOMAIN=

# Logging
LOG_LEVEL=INFO
