# Run mode: live | replay | mock
RUN_MODE=mock

# Database — default is local SQLite (zero-install). Leave unset to use it.
# Production swap (no code change): postgresql+psycopg://localhost:5432/mysteryshop
DATABASE_URL=sqlite:///maple.db

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# Vapi (required when RUN_MODE=live)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# ngrok static domain used for Vapi server.url (e.g. my-tunnel.ngrok.app)
NGROK_DOMAIN=

# Logging
LOG_LEVEL=INFO
